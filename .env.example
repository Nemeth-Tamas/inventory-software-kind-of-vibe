# Port kiosztás a Docker Compose-hoz:
# Kiválasztott véletlenszerű portok, hogy elkerüljük az ütközéseket a gazdagépen:
# Frontend (React): 18080 -> Nginx Proxy Manager (NPM) ide fog mutatni
# Backend (FastAPI): 18000 -> NPM opcionálisan ide mutathat a /api útvonalakhoz (vagy a frontend proxizza)
# PostgreSQL: 15432 (nem publikus, csak belső hálózaton, de ha szükséges, ezen a porton érhető el)
# Redis: 16379 (csak belső hálózaton)

FRONTEND_PORT=18080
BACKEND_PORT=18000
POSTGRES_PORT=15432
REDIS_PORT=16379
